---
const bonus = [
  {
    num: "01",
    titulo: "Receitas para crianças seletivas",
    descricao: "Comidinhas que agradam e aproximam sem esforço. Preparos rápidos, práticos, nutritivos e testados por quem vive a seletividade alimentar – Pratos que despertam curiosidade, prazer e vontade de experimentar.",
    valor: "R$69,00",
    img: "/img/083507-copy.webp",
  },
  {
    num: "02",
    titulo: "Diário da conexão com a comida",
    descricao: "Um guia prático com atividades diárias para transformar a mesa em momento de afeto.",
    valor: "R$69,00",
    img: "/img/0917071.webp",
  },
  {
    num: "03",
    titulo: "Kit brincando de comer",
    descricao: "Imprima, brinque e transforme o momento da refeição em uma experiência divertida. Jogos e atividades para que seu filho descubra o prazer de comer brincando.",
    valor: "R$99,00",
    img: "/img/093507-copy.webp",
  },
];
---

<!-- Seção Bônus -->
<section
  class="py-16 md:py-24 px-6 md:px-10"
  style="background: linear-gradient(90deg, #FEB45D 0%, #FDD8AC 100%);"
>
  <div class="max-w-5xl mx-auto">
    <!-- Header -->
    <div
      class="rounded-xl px-10 py-16 flex flex-col items-center gap-6 mb-10 relative overflow-hidden"
      style="background-color: #FFFFFF;"
    >
      <!-- Logo flutuante -->
      <div class="relative -mt-28 md:-mt-32">
        <img
          src="/img/095704.svg"
          alt="Logo Comer Bem Sem Estresse"
          class="w-36 h-auto object-contain"
          loading="lazy"
        />
      </div>

      <h2
        class="text-3xl md:text-4xl leading-tight text-center"
        style="font-family: 'Factul', sans-serif; color: #3A3A3A;"
      >
        Bônus Exclusivos
      </h2>
      <p class="text-base md:text-lg text-center" style="color: #525252;">
        E para acelerar o seu avanço, você receberá de Bônus:
      </p>

      <!-- Cards dos bônus -->
      <div class="w-full grid grid-cols-1 md:grid-cols-3 gap-6 mt-4">
        {bonus.map((b) => (
          <div
            class="rounded-2xl overflow-hidden shadow-sm"
            style="background: radial-gradient(at center center, #3B634C 0%, #244030 100%);"
          >
            <!-- Topo -->
            <div class="px-8 py-8">
              <span
                class="text-sm font-semibold uppercase tracking-widest mb-4 block"
                style="color: #FFDDB5; font-family: 'Factul', sans-serif;"
              >
                BÔNUS {b.num}
              </span>
              <h3
                class="text-xl leading-snug mb-3"
                style="font-family: 'Factul', sans-serif; color: #FFFFFF;"
              >
                {b.titulo}
              </h3>
              <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.83);">
                {b.descricao}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
