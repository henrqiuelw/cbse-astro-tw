---
const bonuses = [
  {
    badge: 'BÔNUS 01',
    title: 'Receitas para crianças seletivas',
    desc: 'Comidinhas que agradam e aproximam sem esforço. Preparos rápidos, práticos, nutritivos e testados por quem vive a seletividade alimentar – Pratos que despertam curiosidade, prazer e vontade de experimentar.',
    img: 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/083507-copy.webp',
    outerBR: '10px', outerBg: 'rgba(255, 201, 95, 0)', imgConH: '269px',
    imgOffTop: '-47px', imgWidth: '419px',
  },
  {
    badge: 'BÔNUS 02',
    title: 'Diário da conexão com a comida',
    desc: 'Um guia prático com atividades diárias para transformar a mesa em momento de afeto.',
    img: 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/0917071.webp',
    outerBR: '10px', outerBg: 'rgba(255, 201, 95, 0.08)', imgConH: '295px',
    imgOffTop: '-15px', imgWidth: '441px',
  },
  {
    badge: 'BÔNUS 03',
    title: 'Kit brincando de comer',
    desc: 'Imprima, brinque e transforme o momento da refeição em uma experiência divertida. Jogos e atividades para que seu filho descubra o prazer de comer brincando.',
    img: 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/093507-copy.webp',
    outerBR: '0px', outerBg: 'rgba(255, 201, 95, 0)', imgConH: '160px',
    imgOffTop: '-21px', imgWidth: '406px',
  },
];
---

<!-- Container 11: Bônus Exclusivos (f1ca97c) -->
<!-- Section clips horizontal overflow but allows vertical -->
<section
  class="w-full flex flex-col items-center px-[19.5px] overflow-x-clip overflow-y-visible"
  style="background-color: rgba(240, 232, 221, 0.24); border-top: 1px solid rgba(0, 0, 0, 0.05);"
>
  <div class="w-full max-w-[1280px] flex flex-col items-center" style="gap: 100px; padding: 60px 0;">

    <!-- Heading (e53324f) -->
    <h2
      class="text-[33.54px] lg:text-[40px] leading-[1.2em] text-center"
      style="font-family: Factul, sans-serif; color: rgb(35, 47, 48);"
    >
      <span class="underline-inner">Bônus Exclusivos</span>
    </h2>

    <!-- Subtitle (93f5768) -->
    <p
      class="text-[18px] leading-[27px] text-center font-normal -mt-[80px]"
      style="font-family: Inter, sans-serif; color: rgba(0, 0, 0, 0.83);"
    >
      E para acelerar o seu avanço, você receberá de Bônus:
    </p>

    <!-- Bonus Cards -->
    {bonuses.map((bonus) => (
      <div
        class="w-full max-w-[351px] lg:max-w-[1140px]"
        style={`border: 1px solid rgb(253, 253, 253); border-radius: ${bonus.outerBR}; background-color: ${bonus.outerBg};`}
      >
        <!-- Inner: column-reverse, overflow visible (images overflow freely) -->
        <div
          class="flex flex-col-reverse lg:flex-row rounded-[16px] overflow-visible"
          style="background-image: linear-gradient(rgb(36, 64, 48) 0%, rgb(78, 136, 103) 100%);"
        >
          <!-- Image Container -->
          <div class="overflow-visible flex-shrink-0 lg:w-[40%] relative" style={`height: ${bonus.imgConH};`}>
            <img
              src={bonus.img}
              alt={bonus.title}
              class="max-w-none h-auto"
              style={`margin-top: ${bonus.imgOffTop}; object-fit: fill; width: ${bonus.imgWidth};`}
              loading="lazy"
            />
          </div>

          <!-- Text Container -->
          <div
            class="flex flex-col items-center justify-center p-[40px] flex-1 text-center"
            style="gap: 15px;"
          >
            <span
              class="bonus-badge text-[16px] font-normal text-white rounded-full leading-[16px] tracking-[1.9px] relative overflow-hidden"
              style="font-family: Inter, sans-serif; background-color: rgb(219, 185, 83); padding: 12px 24px;"
            >
              {bonus.badge}
            </span>

            <p
              class="text-[29.25px] font-semibold leading-[35.1px] text-white w-full"
              style="font-family: Inter, sans-serif;"
            >
              {bonus.title}
            </p>

            <div class="w-[267px]" style="border-top: 1px solid rgba(255, 255, 255, 0.13);"></div>

            <p
              class="text-[18px] font-normal leading-[23.4px] w-full"
              style="font-family: Inter, sans-serif; color: rgba(255, 255, 255, 0.93);"
            >
              {bonus.desc}
            </p>
          </div>
        </div>
      </div>
    ))}

  </div>
</section>

<style>
  .bonus-badge::before {
    content: "";
    position: absolute;
    top: 0;
    left: -10%;
    width: 90px;
    height: 64px;
    background: linear-gradient(10deg, rgb(255, 255, 255) 12.81%, rgba(209, 210, 234, 0) 66.66%);
    opacity: 0;
    animation: shinery 3s ease-in-out infinite;
  }
  @keyframes shinery {
    0%, 100% { left: -10%; opacity: 0; }
    20% { opacity: 1; }
    48% { left: 120%; opacity: 1; }
    51% { opacity: 0; }
  }
</style>
