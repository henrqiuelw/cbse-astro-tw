---
const fases = [
  {
    semana: "Semana 1",
    fase: "FASE DIAGNÓSTICA",
    titulo: "Identifique a causa da seletividade alimentar",
    descricao: "Entenda o que está por trás da seletividade e comece a mudar a percepção do seu filho com a comida.",
    modulos: [
      {
        nome: "Módulo 1:",
        desc: "O cérebro seletivo – Aprenda como transformar o cérebro seletivo do seu filho em um cérebro aberto a novas experimentações – A hora é de reprogramar.",
      },
      {
        nome: "Módulo 2:",
        desc: "Compreendendo a seletividade – Quais são as causas individualizadas, estágios e estratégias personalizadas.",
      },
    ],
  },
  {
    semana: "Semana 2",
    fase: "FASE REESTRUTURAÇÃO",
    titulo: "Reestruture os fatores fortalecedores da Seletividade alimentar",
    descricao: "Torne o ambiente favorável a novas experimentações, aumentando a segurança e autonomia do pequeno",
    modulos: [
      {
        nome: "Módulo 3:",
        desc: "O método comer bem sem estresse – Entenda o método e comece a implementar mudanças essenciais que trarão resultados reais.",
      },
    ],
  },
  {
    semana: "Semana 3",
    fase: "FASE ALIMENTAR",
    titulo: "Seu pequeno foi preparado nas semanas anteriores para chegar até aqui",
    descricao: "Estratégias eficazes de aproximação, exposição e oferta lúdica para autonomia alimentar do seu pequeno",
    modulos: [
      {
        nome: "Módulo 4:",
        desc: "Transformação sem resistência – Torne a alimentação uma atividade natural da rotina.",
      },
    ],
  },
  {
    semana: "Semana 4",
    fase: "FASE CONSOLIDAÇÃO",
    titulo: "Ferramentas lúdicas para auxiliar na consolidação da metodologia do aprendizado do comer",
    descricao: "Como incentivar o pequeno, de forma lúdica, a comer com naturalidade e autonomia",
    modulos: [
      {
        nome: "Módulo 5:",
        desc: "Aprendizado consolidado – Fixe o conhecimento com materiais complementares e práticos. Utilize aqui o seu Diário da conexão com a comida e o livro de Receitas para crianças seletivas, que você ganhou como bônus.",
      },
      {
        nome: "Módulo de Atividades:",
        desc: "Você terá acesso ao Kit brincando de comer, que você também recebeu de bônus. Imprima, brinque e transforme o momento da refeição em uma experiência divertida e sem estresse. Você terá acesso a vários joguinhos muito divertidos para utilizar com o seu pequeno que serão essenciais nessa transformação e terá muita conexão e alegria à mesa todos os dias.",
      },
    ],
  },
];
---

<!-- Seção Como Funciona -->
<section class="como-section">
  <div class="como-inner">

    <!-- Heading -->
    <h1 class="como-heading">
      <span class="underline-inner">Confira como funciona</span> o Comer bem sem estresse:
    </h1>

    <!-- Subtitle -->
    <p class="como-subtitle">Um método em 4 semanas</p>

    <!-- Cream card container -->
    <div class="como-card">

      <!-- Hint text -->
      <p class="como-hint">Clique nos módulos para saber mais</p>

      <!-- Accordion -->
      <div class="como-accordion">
        {fases.map((fase, i) => (
          <details class="como-details" >
            <summary class="como-summary">
              <!-- Caret icon -->
              <span class="como-caret" aria-hidden="true">
                <svg class="caret-closed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" width="15" height="15" fill="currentColor">
                  <path d="M137.4 374.6c12.5 12.5 32.8 12.5 45.3 0l128-128c9.2-9.2 11.9-22.9 6.9-34.9s-16.6-19.8-29.6-19.8l-256 0c-12.9 0-24.6 7.8-29.6 19.8s-2.2 25.7 6.9 34.9l128 128z"/>
                </svg>
                <svg class="caret-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 512" width="15" height="15" fill="currentColor">
                  <path d="M246.6 278.6c12.5-12.5 12.5-32.8 0-45.3l-128-128c-9.2-9.2-22.9-11.9-34.9-6.9s-19.8 16.6-19.8 29.6l0 256c0 12.9 7.8 24.6 19.8 29.6s25.7 2.2 34.9-6.9l128-128z"/>
                </svg>
              </span>
              <!-- Text -->
              <div class="como-summary-text">
                <span class="como-semana">{fase.semana}</span><br/>
                {fase.fase}
              </div>
            </summary>

            <!-- Content -->
            <div class="accordion-content">
              <div class="como-content">
                <!-- Title (bold italic) -->
                <p class="como-fase-titulo">{fase.titulo}</p>
                <!-- Description -->
                <p class="como-fase-desc">{fase.descricao}</p>
                <!-- Module list -->
                <ul class="como-module-list">
                  {fase.modulos.map((mod) => (
                    <li class="como-module-item">
                      <span class="como-module-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 60" width="22" height="22">
                          <rect fill="#6bb577" height="58" rx="7" width="58" x="1" y="1"></rect>
                          <path d="m24.375 47c-.892 0-1.751-.356-2.386-.996l-9-9.067c-1.318-1.327-1.318-3.481 0-4.808 1.317-1.328 3.455-1.328 4.772 0l6.248 6.294 17.915-24.064c1.121-1.502 3.238-1.805 4.725-.68 1.492 1.127 1.794 3.258.676 4.76l-20.25 27.2c-.587.789-1.485 1.282-2.46 1.351-.08.006-.16.009-.239.009z" fill="#fff"></path>
                        </svg>
                      </span>
                      <span class="como-module-text">
                        <span class="texto">{mod.nome}</span> {mod.desc}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </details>
        ))}
      </div>

    </div>

  </div>
</section>

<style>
  /* Section — dark green gradient */
  .como-section {
    background: linear-gradient(145deg, #244030 0%, #4e8867 100%);
    padding: 0;
    margin-bottom: -4px;
  }

  .como-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 80px 0 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  @media (max-width: 767px) {
    .como-inner {
      padding: 10% 5% 0;
    }
  }

  /* Heading */
  .como-heading {
    font-family: 'Factul', sans-serif;
    font-size: 40px;
    font-weight: 400;
    line-height: 1.2em;
    color: #ffffff;
    text-align: center;
    text-wrap: balance;
    margin: 0;
    max-width: 640px;
  }
  @media (max-width: 767px) {
    .como-heading {
      font-size: 6.5vw;
      max-width: 100%;
    }
  }

  /* Subtitle */
  .como-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 22px;
    font-weight: 400;
    line-height: 1.5em;
    color: #ffffff;
    text-transform: uppercase;
    text-align: center;
    margin: 0;
  }
  @media (max-width: 767px) {
    .como-subtitle {
      font-size: 4.5vw;
    }
  }

  /* Cream card container */
  .como-card {
    background-color: #fcf9f2;
    border-radius: 10px 10px 0 0;
    padding: 20px 40px 60px;
    width: 666px;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  @media (max-width: 767px) {
    .como-card {
      width: 100%;
      padding: 20px 20px 40px;
    }
  }

  /* Hint text */
  .como-hint {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    font-style: italic;
    color: rgba(116, 116, 116, 0.72);
    text-align: center;
    margin: 0;
  }

  /* Accordion container */
  .como-accordion {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Details item */
  .como-details {
    margin-bottom: 19px;
  }
  .como-details:last-child {
    margin-bottom: 0;
  }

  /* Summary header — orange gradient */
  .como-summary {
    background: linear-gradient(180deg, #c47519 0%, #e7b478 100%);
    padding: 20px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    list-style: none;
  }
  .como-summary::-webkit-details-marker {
    display: none;
  }
  .como-summary::marker {
    display: none;
  }

  /* Caret icon */
  .como-caret {
    flex-shrink: 0;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 15px;
    height: 15px;
  }
  .como-caret svg {
    width: 15px;
    height: 15px;
  }
  /* Closed state: show down caret, hide right caret */
  .caret-closed {
    display: block;
  }
  .caret-open {
    display: none;
  }
  /* Open state: show right caret, hide down caret */
  .como-details[open] .caret-closed {
    display: none;
  }
  .como-details[open] .caret-open {
    display: block;
  }

  /* Summary text */
  .como-summary-text {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.7em;
    color: #ffffff;
  }

  /* Semana label (white pill on orange header) */
  .como-semana {
    color: #c47519;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.7em;
    background-color: #ffffff;
    border-radius: 100px;
    padding: 5px 13px;
  }

  /* Accordion content */
  .como-content {
    padding: 10px 0 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Phase title (bold italic) */
  .como-fase-titulo {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    font-style: italic;
    line-height: 1.5em;
    color: rgba(0, 0, 0, 0.83);
    margin: 0;
  }

  /* Phase description */
  .como-fase-desc {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.5em;
    color: rgba(0, 0, 0, 0.83);
    margin: 0;
  }

  /* Module list */
  .como-module-list {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: center;
  }

  .como-module-item {
    display: flex;
    align-items: center;
    gap: 7px;
    padding-bottom: 14.5px;
  }
  .como-module-item:last-child {
    padding-bottom: 0;
  }

  .como-module-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
  }
  .como-module-icon svg {
    width: 22px;
    height: 22px;
  }

  .como-module-text {
    font-family: 'Inter', sans-serif;
    font-size: 20px;
    font-weight: 400;
    font-style: italic;
    line-height: 1.5em;
    color: #1c1e20;
    text-align: center;
  }
  @media (max-width: 767px) {
    .como-module-text {
      font-size: 16px;
    }
  }
</style>
