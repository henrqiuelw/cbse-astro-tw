---
const HOTMART = "https://pay.hotmart.com/N90113161T?off=ukulpso1";

const antes = [
  "Repertório alimentar limitado e sem evolução previsível",
  "Refeições dependentes de negociações constantes",
  "Muitas tentativas, poucas respostas claras",
  "Alimentação ocupando energia mental excessiva",
];

const depois = [
  "Repertório alimentar ampliando de forma progressiva",
  "Refeições integradas à rotina, com menos intervenção e sem desgaste emocional",
  "Decisões alimentares mais claras e seguras",
  "Criança desenvolvendo maior autonomia à mesa",
];
---

<!-- Seção Comparação (Antes/Depois) -->
<section class="comp-section">
  <div class="comp-inner">
    <div class="comp-card">

      <!-- Heading "Hoje, sem..." -->
      <h1 class="comp-heading">
        Hoje, <span class="underline-red">sem</span> um sistema alimentar estruturado:
      </h1>

      <!-- Lista "antes" com ícone X vermelho -->
      <ul class="comp-list">
        {antes.map((item) => (
          <li class="comp-list-item">
            <span class="comp-icon-red">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 72 76" width="22" height="22">
                <rect fill="#af2828" height="72" rx="17.35" width="72" y="4"></rect>
                <rect fill="#c93131" height="72" rx="17.35" width="72"></rect>
                <path d="m43.5 40.14 8.6 8.6a4.23 4.23 0 0 1 0 6l-.38.38a4.23 4.23 0 0 1-6 0l-8.6-8.6a1.61 1.61 0 0 0-2.28 0l-8.6 8.6a4.23 4.23 0 0 1-6 0l-.38-.38a4.23 4.23 0 0 1 0-6l8.6-8.6a1.61 1.61 0 0 0 0-2.28l-8.6-8.6a4.23 4.23 0 0 1 0-6l.38-.38a4.23 4.23 0 0 1 6 0l8.6 8.6a1.61 1.61 0 0 0 2.28 0l8.6-8.6a4.23 4.23 0 0 1 6 0l.38.38a4.23 4.23 0 0 1 0 6l-8.6 8.6a1.61 1.61 0 0 0 0 2.28z" fill="#fff"></path>
              </svg>
            </span>
            <span class="comp-list-text">{item}</span>
          </li>
        ))}
      </ul>

      <!-- Divider -->
      <div class="comp-divider"></div>

      <!-- Heading "Com..." -->
      <h1 class="comp-heading">
        <span class="underline-verde">Com</span> um método aplicado com constância:
      </h1>

      <!-- Lista "depois" com ícone check verde -->
      <ul class="comp-list">
        {depois.map((item) => (
          <li class="comp-list-item">
            <span class="comp-icon-green">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 60" width="22" height="22">
                <rect fill="#6bb577" height="58" rx="7" width="58" x="1" y="1"></rect>
                <path d="m24.375 47c-.892 0-1.751-.356-2.386-.996l-9-9.067c-1.318-1.327-1.318-3.481 0-4.808 1.317-1.328 3.455-1.328 4.772 0l6.248 6.294 17.915-24.064c1.121-1.502 3.238-1.805 4.725-.68 1.492 1.127 1.794 3.258.676 4.76l-20.25 27.2c-.587.789-1.485 1.282-2.46 1.351-.08.006-.16.009-.239.009z" fill="#fff"></path>
              </svg>
            </span>
            <span class="comp-list-text">{item}</span>
          </li>
        ))}
      </ul>

      <!-- CTA -->
      <div class="comp-cta-wrap">
        <a
          href={HOTMART}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-grad comp-cta"
        >
          Quero iniciar o acompanhamento
        </a>
      </div>

      <!-- Closing text -->
      <p class="comp-closing">
        O Comer bem sem estresse vai lhe dar <span class="texto">clareza e direção nessa transformação</span>
      </p>

    </div>
  </div>
</section>

<style>
  /* Section background: gold/orange gradient */
  .comp-section {
    background: linear-gradient(304deg, #bb7d34 0%, #f8b361 100%);
    padding: 0;
  }

  .comp-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 60px 40px;
    display: flex;
    justify-content: center;
  }
  @media (max-width: 767px) {
    .comp-inner {
      padding: 10% 5%;
    }
  }

  /* White card with radial gradient */
  .comp-card {
    background: radial-gradient(circle, #f5f1e9 0%, #ffffff 100%);
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 10px;
    padding: 40px 80px;
    max-width: 691px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  @media (max-width: 767px) {
    .comp-card {
      padding: 30px 20px;
    }
  }

  /* Headings */
  .comp-heading {
    font-family: 'Factul', sans-serif;
    font-size: 32px;
    font-weight: 400;
    line-height: 1.2em;
    color: #1c3124;
    text-align: center;
    text-wrap: balance;
    margin: 0 0 20px 0;
  }
  @media (max-width: 767px) {
    .comp-heading {
      font-size: 6.1vw;
    }
  }

  /* Underline styles */
  .underline-red {
    display: inline;
    box-shadow: inset 0 -7px 0 0 #ff0b00;
  }
  .underline-verde {
    display: inline;
    box-shadow: inset 0 -7px 0 0 #25a75c;
  }

  /* Lists */
  .comp-list {
    list-style: none;
    padding: 0;
    margin: 0 0 10px 0;
    width: 100%;
    max-width: 530px;
  }

  .comp-list-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 6px 0;
  }

  .comp-icon-red,
  .comp-icon-green {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    margin-top: 2px;
  }
  .comp-icon-red svg,
  .comp-icon-green svg {
    width: 22px;
    height: 22px;
  }

  .comp-list-text {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 400;
    font-style: italic;
    line-height: 1.4em;
    color: #1c1e20;
  }

  /* Divider */
  .comp-divider {
    width: 100%;
    max-width: 530px;
    height: 0;
    border-top: 1px solid rgba(0, 0, 0, 0.17);
    margin: 20px 0 30px 0;
  }

  /* CTA */
  .comp-cta-wrap {
    display: flex;
    justify-content: center;
    margin: 20px 0 16px 0;
  }

  .comp-cta {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.9px;
    text-transform: uppercase;
    padding: 20px 40px;
  }

  /* Closing text */
  .comp-closing {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 400;
    font-style: italic;
    line-height: 1.4em;
    color: #584c4d;
    text-align: center;
    margin: 0;
  }
</style>
