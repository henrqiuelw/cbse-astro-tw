---
// CtaFinalSection.astro — Container 16 (4a4cb13)
// Computed desktop: bg #FFF, pad 0 40px, flex-row
// Inner (1b9df37): w=883, radial-gradient(#3B634C 0%, #244030 100%), borderRadius 20px, flex-row, gap 20px
// Image (fd44f89): 428x464, static, overflow visible
// Text container (6184acc): w=435, pad 10px
// Heading: Factul 32px/35.2px, white
// Text: Inter 16px, rgba(255,255,255,0.84)
// NO button in this section
// Computed mobile: pad 0 20px, heading 24.96px, img 350x380, textConPad 21px 35px 35px, innerFlexDir row (still)
---

<section class="w-full bg-white flex flex-col items-center px-[20px] lg:px-[40px]">
  <div
    class="w-full max-w-[883px] flex flex-row rounded-[20px] overflow-hidden"
    style="background-image: radial-gradient(rgb(59, 99, 76) 0%, rgb(36, 64, 48) 100%); gap: 20px;"
  >
    <!-- Image -->
    <div class="flex-shrink-0 overflow-visible">
      <img
        src="https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/150706.webp"
        alt="Mãe e filha na cozinha"
        class="w-[150px] lg:w-[428px] h-auto"
        loading="lazy"
      />
    </div>
    <!-- Text -->
    <div class="flex flex-col justify-center" style="padding: 21px 35px 35px;">
      <div class="flex flex-col" style="gap: 15px;">
        <h2
          class="text-[6.4vw] lg:text-[32px] leading-[1.1em] lg:leading-[35.2px] font-normal text-white"
          style="font-family: Factul, sans-serif;"
        >
          As refeições não precisam ser momentos de tensão!
        </h2>
        <p
          class="text-[16px] leading-[24px] font-normal"
          style="font-family: Inter, sans-serif; color: rgba(255, 255, 255, 0.84);"
        >
          Elas podem ser memórias felizes, leves e cheias de afeto. O próximo passo está nas suas mãos. Descubra como essa transformação é possível.
        </p>
      </div>
    </div>
  </div>
</section>
