---
const depoimentos = Array.from({ length: 13 }, (_, i) => {
  const roman = ["I","II","III","IV","V","VI","VII","VIII","IX","X","XI","XII","XIII"][i];
  return {
    src: `/img/Depoimento-CBSE-${roman}.webp`,
    alt: `Depoimento CBSE ${roman}`,
  };
});
---

<!-- Seção Depoimentos -->
<section class="py-16 md:py-24 px-4 md:px-6" style="background-color: #FFFFFF;">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-10">
      <h2
        class="text-3xl md:text-4xl leading-tight"
        style="font-family: 'Factul', sans-serif; color: #3A3A3A;"
      >
        <span class="underline-inner">Veja os resultados de mães e alunas</span> que saíram do improviso com a alimentação dos seus filhos para seguir <span class="underline-inner">um método estruturado:</span>
      </h2>
    </div>

    <!-- Swiper carousel -->
    <div class="swiper depoimentos-swiper">
      <div class="swiper-wrapper">
        {depoimentos.map((dep) => (
          <div class="swiper-slide">
            <img
              src={dep.src}
              alt={dep.alt}
              class="w-full h-auto rounded-lg shadow-sm"
              style="border-color: rgba(0,0,0,0.08);"
              loading="lazy"
            />
          </div>
        ))}
      </div>
      <!-- Pagination -->
      <div class="swiper-pagination"></div>
    </div>
  </div>
</section>

<style>
  .depoimentos-swiper {
    width: 100%;
    padding-bottom: 3rem;
  }
  
  .swiper-slide {
    width: auto;
  }
  
  .swiper-pagination {
    bottom: 0 !important;
  }
  
  :global(.swiper-pagination-bullet) {
    background-color: #DBB953;
    opacity: 0.3;
  }
  
  :global(.swiper-pagination-bullet-active) {
    opacity: 1;
  }
</style>

<script>
  // Lazy load Swiper when section is visible
  const initSwiper = () => {
    const swiperContainer = document.querySelector('.depoimentos-swiper');
    if (!swiperContainer) return;

    // Check if already initialized
    if (swiperContainer.classList.contains('swiper-initialized')) return;

    // Load Swiper CSS
    const loadCSS = () => {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css';
      document.head.appendChild(link);
    };

    // Load Swiper JS
    const loadJS = () => {
      return new Promise((resolve) => {
        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js';
        script.onload = resolve;
        document.head.appendChild(script);
      });
    };

    // Init Swiper after loading
    const setupSwiper = () => {
      // @ts-ignore
      new Swiper('.depoimentos-swiper', {
        slidesPerView: 2,
        spaceBetween: 15,
        loop: true,
        autoplay: {
          delay: 5000,
          disableOnInteraction: false,
          pauseOnMouseEnter: true,
        },
        speed: 500,
        pagination: {
          el: '.swiper-pagination',
          clickable: true,
        },
        breakpoints: {
          768: {
            slidesPerView: 3,
            spaceBetween: 20,
          },
          1024: {
            slidesPerView: 5,
            spaceBetween: 20,
          },
        },
      });
    };

    // Load assets and init
    loadCSS();
    loadJS().then(setupSwiper);
  };

  // Intersection Observer to lazy load Swiper
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          initSwiper();
          observer.disconnect();
        }
      });
    }, {
      rootMargin: '50px' // Start loading 50px before section is visible
    });

    document.addEventListener('DOMContentLoaded', () => {
      const section = document.querySelector('.depoimentos-swiper')?.closest('section');
      if (section) {
        observer.observe(section);
      }
    });
  } else {
    // Fallback for older browsers
    document.addEventListener('DOMContentLoaded', initSwiper);
  }
</script>
