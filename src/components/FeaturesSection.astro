---
// FeaturesSection.astro — Container 5 (id: 3704ea8)
// 5 cards in flex-row wrap, 950px container, gap 30px
// Each card: icon + title(20px/400) + desc(16px/600 border-left green) + detail(18px/400)

const decorativeUrl = 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/083313-copy.webp';
const iconUrl = 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/141704.svg';

const cards = [
  {
    title: 'Método Estruturado',
    desc: 'É um método criado por uma nutricionista especialista em Seletividade alimentar e desenvolvimento infantil',
    detail: 'Você não recebe opiniões soltas, mas um sistema com lógica clara de aplicação',
  },
  {
    title: 'Mudança de Fundamento',
    desc: 'Atua na causa do repertório alimentar restrito, e não apenas no comportamento à mesa.',
    detail: 'O foco não é convencer a criança a comer, mas criar condições favoráveis para ela avançar.',
  },
  {
    title: 'Sequência Progressiva',
    desc: 'Segue uma sequência lógica de etapas, aplicáveis à rotina real da família.',
    detail: 'Cada fase prepara para a próxima, evitando tentativas aleatórias ou mudanças radicais.',
  },
  {
    title: 'Autonomia Alimentar',
    desc: 'Desenvolve autonomia alimentar progressiva, com menos intervenção e menos negociação.',
    detail: 'A alimentação deixa de ocupar o centro da rotina e vira uma atividade normal.',
  },
  {
    title: 'Flexível ao Desenvolvimento',
    desc: 'Permite ajustar o método às necessidades alimentares e ao momento de desenvolvimento do seu filho.',
    detail: 'Sem fórmulas engessadas: método com critério.',
  },
];
---

<section class="overflow-visible" style="background-color: #FEF4DF;">
  <div class="max-w-[1140px] mx-auto px-[5%] lg:px-0 py-[10%] lg:py-[60px] relative">

    <!-- Imagem decorativa topo (08dadbe): visible mobile, hidden desktop -->
    <!-- Widget 300px, container 405px via negative margins -->
    <div class="lg:hidden overflow-visible mb-[30px]">
      <div style="margin: -31% -13% -22% -22%;">
        <img src={decorativeUrl} alt="" class="w-full h-auto" loading="lazy" />
      </div>
    </div>

    <!-- Heading (03949ff) -->
    <h2 class="font-factul font-normal text-[6.1vw] md:text-[32px] leading-[1.2em] text-[#1C3124] text-center mb-[30px]">
      <span class="underline-inner">O Comer bem sem estresse é um método estruturado</span> para sair do improviso e construir autonomia alimentar:
    </h2>

    <!-- Cards wrapper (ebff15c): 950px, flex-row wrap, gap 30px -->
    <div class="w-full max-w-[950px] mx-auto flex flex-row flex-wrap gap-[30px] pt-0 lg:pt-[40px]">

      {cards.map((card) => (
        <div
          class="flex-1 min-w-[250px] flex flex-col gap-[20px] p-[40px] rounded-[10px]"
          style="background-color: #FFFEFB; border-width: 0 1px 1px 1px; border-style: solid; border-color: #00000026;"
        >
          <!-- Ícone -->
          <img src={iconUrl} alt="" class="w-[46px] h-auto" width="46" loading="lazy" />

          <!-- Título: Factul 20px/400, #584C4D -->
          <p class="font-factul font-normal text-[20px] text-[#584C4D]">
            {card.title}
          </p>

          <!-- Desc: Inter 16px/600, #584C4D, border-left 2px #58DBB1, pl-[20px] -->
          <p
            class="text-[16px] leading-[1.4em] text-[#584C4D] pl-[20px]"
            style="font-family: Inter, sans-serif; font-weight: 600; border-left: 2px solid #58DBB1;"
          >
            {card.desc}
          </p>

          <!-- Detail: Inter 18px(desktop) 16px(mobile)/400, #584C4D -->
          <p class="text-[16px] lg:text-[18px] leading-[1.4em] text-[#584C4D]" style="font-family: Inter, sans-serif;">
            {card.detail}
          </p>
        </div>
      ))}

      <!-- Imagem decorativa mid (7d5ad76): hidden mobile, visible desktop -->
      <div class="hidden lg:block w-[31%] overflow-visible">
        <img
          src={decorativeUrl}
          alt=""
          class="relative z-0 w-[570px] max-w-none"
          style="margin: -11% -52% -40% -40%;"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Botão CTA (7820224) -->
    <div class="text-center mt-[20px]">
      <a
        href="https://pay.hotmart.com/N90113161T?off=ukulpso1"
        class="inline-block text-[16px] font-semibold uppercase tracking-[0.9px] text-white
          px-[40px] py-[20px] rounded-[1000px] text-center"
        style="font-family: Inter, sans-serif; background-image: linear-gradient(to right, #2D8050 0%, #1FBF63 51%, #2D8050 100%); background-size: 200% auto; transition: 0.5s;"
      >
        Quero um sistema que funcione
      </a>
    </div>
  </div>
</section>
