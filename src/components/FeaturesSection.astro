---
// FeaturesSection.astro — Container 5 (id: 3704ea8)
// JSON source: page-2.json, all values from _elementor_data
//
// Section (3704ea8): flex-row wrap, boxed 1140px, align center, justify center
//   padding: 60px 0 200px 0 (desktop), 10% (mobile)
//   gap: 20px (desktop), 30px (mobile)
//   bg: #FEF4DF
//
// Image top (08dadbe): hidden desktop/laptop, visible mobile
//   _margin_mobile: -31% -13% -22% -22%
//
// Heading (03949ff): Factul 32px/400, color #1C3124, center
//   width: 87% desktop, 67.837% mobile (but renders full-width)
//   _margin_mobile: 0 -20px 0 -20px
//
// Cards grid (ebff15c): CSS Grid, 950px, gap 30px (desktop), 20px (mobile)
//   padding: 40px 0 0 0 (desktop), 0 (mobile)
//   tablet: width 70%, gap 42px col / 80px row
//
// Each card: bg #FFFEFB, padding 40px (desktop), 10% (mobile)
//   box-shadow: 0px 34.319px 44.764px 0px rgba(0,0,0,0.06)
//   border-radius: 10px
//   bg_image_mobile: 142704-copy.webp (decorative curve)
//
// Card texts:
//   [0] title: Factul 20px/400, #584C4D
//   [1] desc: Inter 16px/600, #584C4D, border-left 2px #58DBB1, pl 20px
//   [2] detail: Inter 18px/400, #584C4D
//
// Image bottom (7d5ad76): hidden mobile, visible desktop
//   widget width 31% of grid, img 570px via margins -11% -52% -40% -40%
//
// Button (7820224): same gradient CTA

const decorativeUrl = 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/083313-copy.webp';
const iconUrl = 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/141704.svg';
const cardBgMobile = 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/142704-copy.webp';

const cards = [
  {
    title: 'Método Estruturado',
    desc: 'É um método criado por uma nutricionista especialista em Seletividade alimentar e desenvolvimento infantil',
    detail: 'Você não recebe opiniões soltas, mas um sistema com lógica clara de aplicação',
  },
  {
    title: 'Mudança de Fundamento',
    desc: 'Atua na causa do repertório alimentar restrito, e não apenas no comportamento à mesa.',
    detail: 'O foco não é convencer a criança a comer, mas criar condições favoráveis para ela avançar.',
  },
  {
    title: 'Sequência Progressiva',
    desc: 'Segue uma sequência lógica de etapas, aplicáveis à rotina real da família.',
    detail: 'Cada fase prepara para a próxima, evitando tentativas aleatórias ou mudanças radicais.',
  },
  {
    title: 'Autonomia Alimentar',
    desc: 'Desenvolve autonomia alimentar progressiva, com menos intervenção e menos negociação.',
    detail: 'A alimentação deixa de ocupar o centro da rotina e vira uma atividade normal.',
  },
  {
    title: 'Flexível ao Desenvolvimento',
    desc: 'Permite ajustar o método às necessidades alimentares e ao momento de desenvolvimento do seu filho.',
    detail: 'Sem fórmulas engessadas: método com critério.',
  },
];
---

<!-- Section (3704ea8): flex-row wrap, boxed 1140px -->
<section
  class="relative flex flex-row flex-wrap justify-center items-center
    overflow-visible
    px-[10%] py-[10%]
    md:px-[5%] md:py-[10%]
    lg:px-0 lg:pt-[60px] lg:pb-[200px]
    gap-[30px] md:gap-[20px] lg:gap-[20px]"
  style="background-color: #FEF4DF; border-top: 1px solid #FFFFFF0F; max-width: 100%;"
>
  <div class="w-full max-w-[1140px] mx-auto flex flex-row flex-wrap justify-center items-center gap-[30px] md:gap-[20px]">

    <!-- Image top (08dadbe): hidden desktop, visible mobile -->
    <!-- _margin_mobile: -31% -13% -22% -22%, widget full-width -->
    <div class="lg:hidden w-full overflow-visible">
      <div style="margin: -31% -13% -22% -22%;">
        <img src={decorativeUrl} alt="" class="w-full h-auto" loading="lazy" />
      </div>
    </div>

    <!-- Heading (03949ff): Factul 32px/400 desktop, 6.1vw mobile -->
    <!-- width: 87% desktop, _margin_mobile: 0 -20px -->
    <div class="w-full lg:w-[87%] self-start lg:self-start text-center">
      <div class="mx-[-20px] md:mx-0">
        <h2 class="font-factul font-normal text-[6.1vw] md:text-[33px] lg:text-[32px]
          leading-[1.2em] md:leading-[1.3em] lg:leading-[1.2em]
          text-[#1C3124] text-center"
          style="text-wrap: balance !important;">
          <span class="underline-inner">O Comer bem sem estresse é um método estruturado</span> para sair do improviso e construir autonomia alimentar:
        </h2>
      </div>
    </div>

    <!-- Cards grid (ebff15c): 950px desktop, 70% tablet, gap 30px/20px -->
    <!-- padding: 40px 0 0 0 desktop, 0 mobile -->
    <div class="w-full lg:w-[950px] md:w-[70%]
      grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3
      gap-[20px] lg:gap-[30px]
      pt-0 lg:pt-[40px]
      items-stretch lg:auto-rows-fr">

      {cards.map((card) => (
        <div
          class="flex flex-col gap-[20px]
            p-[10%] md:p-[40px]
            rounded-[10px]"
          style={`background-color: #FFFEFB; box-shadow: 0px 34.319px 44.764px 0px rgba(0, 0, 0, 0.06); background-image: url('${cardBgMobile}'); background-size: cover; background-position: top center;`}
        >
          <!-- Ícone -->
          <img src={iconUrl} alt="" class="w-[46px] h-auto" width="46" loading="lazy" />

          <!-- Título: Factul 20px/400, #584C4D -->
          <p class="font-factul font-normal text-[20px] text-[#584C4D]">
            {card.title}
          </p>

          <!-- Desc: Inter 16px/600, #584C4D, border-left 2px #58DBB1, pl 20px -->
          <p class="text-[16px] leading-[1.4em] text-[#584C4D] pl-[20px]"
            style="font-family: Inter, sans-serif; font-weight: 600; border-left: 2px solid #58DBB1;">
            {card.desc}
          </p>

          <!-- Detail: Inter 18px(desktop) 16px(mobile)/400, #584C4D -->
          <p class="text-[16px] lg:text-[18px] leading-[1.4em] text-[#584C4D]"
            style="font-family: Inter, sans-serif;">
            {card.detail}
          </p>
        </div>
      ))}

      <!-- Image bottom (7d5ad76): hidden mobile, visible desktop -->
      <!-- Widget 31% of grid, img 570px via margins -11% -52% -40% -40% -->
      <div class="hidden lg:block overflow-visible">
        <img
          src={decorativeUrl}
          alt=""
          class="relative z-0 w-[570px] max-w-none"
          style="margin: -11% -52% -40% -40%;"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Button CTA (7820224) -->
    <a
      href="https://pay.hotmart.com/N90113161T?off=ukulpso1"
      class="inline-block text-[14px] lg:text-[16px] font-semibold uppercase tracking-[0.9px] text-white
        px-[30px] lg:px-[40px] py-[20px] leading-[1.2em] rounded-[1000px] text-center"
      style="font-family: Inter, sans-serif; background-image: linear-gradient(to right, #2D8050 0%, #1FBF63 51%, #2D8050 100%); background-size: 200% auto; transition: 0.5s;"
    >
      Quero um sistema que funcione
    </a>
  </div>
</section>
