---
// HeroSection.astro — Container 1 (id: 43c1cc8)
// Estilos APLICADOS do JSON do Elementor, NUNCA computados
---

<section
  class="hero-section flex flex-col lg:flex-row justify-center items-center gap-[10px]
    pt-0 px-[5%] pb-[15%]
    md:pt-[5%] md:px-[5%] md:pb-[10%]
    lg:pt-[20px] lg:px-0 lg:pb-0"
  style="
    background-color: #F0E9DE;
    background-image: url('https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/100004.webp');
    background-position: bottom center;
    background-size: cover;
    background-repeat: no-repeat;
  "
>
  <!-- Wrapper (7d4521e): w:100%, justify:center, align:center -->
  <div class="w-full flex flex-col justify-center items-center">

    <!-- Glassmorphism (cc9604c): 800px, transparent desktop, mb:-20px -->
    <div
      class="glass-container w-full max-w-[800px] flex flex-col justify-center items-center
        p-[6%_5%_5%_5%] md:p-[40px_40px_20px_40px]
        mb-[-20px]"
      style="
        background-color: #FFFFFF1A;
        border-style: solid;
        border-width: 0 1px 0 1px;
        border-color: #FFFFFF59;
      "
    >
      <!-- Logo: 201px desktop, 40.888% mobile, self:center -->
      <img
        src="https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/095704.svg"
        alt="Comer Bem Sem Estresse"
        class="self-center w-[40.888%] md:w-[201px]
          mt-0 mb-[5%] md:mt-[-20px] md:mb-[20px]"
        width="201"
      />

      <!-- Título: CENTRALIZADO em todos os breakpoints -->
      <!-- width: 87% desktop, 516px tablet, 67.837% mobile -->
      <!-- mobile: margin 0 -4% -3% -4% expande visualmente -->
      <div class="self-center
        w-full md:w-[516px] lg:w-[87%]
        md:mx-0 md:mb-0
        text-center">
        <p class="font-factul font-normal text-[6.3vw] md:text-[36px] lg:text-[43px] leading-[1.2em] lg:leading-[1.1em] text-[#3B3B3B] mx-[-4%] mb-[-3%] md:mx-0 md:mb-0" style="text-wrap: balance;">
          Leve o seu filho de um repertório alimentar restrito para <span class="underline-inner">uma alimentação variada e saudável</span>
        </p>
      </div>

      <!-- Subtítulo: 683px desktop, 73% tablet -->
      <div class="self-center
        w-full md:w-[73%] lg:w-auto lg:max-w-[683px]
        text-center mt-4">
        <p class="font-inter font-normal text-[4.1vw] md:text-[20px] leading-[1.4em] text-[#0F0F0F]">
          um método estruturado para famílias que querem resultados consistentes
        </p>
      </div>
    </div>

    <!-- Video: 801px, border_radius:10px -->
    <!-- Elementor default widget spacing: 20px (--widgets-spacing) -->
    <div class="w-full max-w-[801px] mx-[-4%] md:mx-0 mt-[20px] mb-[20px] relative rounded-[10px] overflow-hidden">
      <video
        id="hero-video"
        src="https://comerbemsemestresse.com.br/wp-content/uploads/2025/12/VSL-4-1.mp4"
        controls
        controlslist="nodownload"
        class="w-full h-auto"
        style="object-fit: cover;"
        preload="metadata"
      ></video>
      <div id="video-overlay" class="absolute inset-0 cursor-pointer bg-cover bg-center"
        style="background-image: url(https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/100104.webp);">
      </div>
    </div>

    <!-- Botão CTA: z-99, self:center, full-width mobile -->
    <a
      href="https://pay.hotmart.com/N90113161T?off=ukulpso1"
      class="btn-grad self-center relative
        w-full md:w-auto
        font-inter font-semibold text-[16px] md:text-[18px]
        leading-[1.2em] uppercase tracking-[0.9px]
        text-white px-[40px] py-[20px]
        rounded-[100px] md:rounded-[1000px]
        text-center z-[99]"
    >
      Quero iniciar o acompanhamento
    </a>
  </div>
</section>
<script>
  const overlay = document.getElementById('video-overlay');
  const video = document.getElementById('hero-video');
  if (overlay && video) {
    overlay.addEventListener('click', () => {
      overlay.style.display = 'none';
      video.play();
    });
  }
</script>

<style>
  .btn-grad {
    background-image: linear-gradient(to right, #2D8050 0%, #1FBF63 51%, #2D8050 100%);
    background-size: 200% auto;
    transition: 0.5s;
    display: block;
  }
  .btn-grad:hover {
    background-position: right center;
  }

  @media (min-width: 1025px) {
    .hero-section {
      background-image: url('https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/093713-copy.webp') !important;
      background-position: top center !important;
    }
  }

  @media (min-width: 1025px) {
    .glass-container {
      background: transparent !important;
      border: none !important;
    }
  }
</style>
