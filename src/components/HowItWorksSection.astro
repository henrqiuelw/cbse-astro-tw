---

<style>
  .acc-content {
    overflow: hidden;
    transition: max-height 0.3s ease-out, opacity 0.3s ease-out;
  }
  @media (min-width: 1025px) {
    .howitworks-section { background: linear-gradient(145deg, #244030 0%, #4E8867 100%) !important; }
  }
</style>
<!-- Container 10: How It Works Section (2b2de84) -->
<section
  class="howitworks-section px-[5%] lg:px-0"
  style="background: linear-gradient(157deg, #244030 56%, #4E8867 100%);"
>
  <div class="w-full max-w-[767px] lg:max-w-[1280px] mx-auto flex flex-col gap-[20px] pt-[105px] lg:pt-[80px]">

    <!-- Heading: Factul 40px/48px white desktop, 28px/33.7px mobile -->
    <h2 class="text-[7.2vw] lg:text-[40px] leading-[1.2em] lg:leading-[48px] text-white max-w-[311px] lg:max-w-[640px] text-center mx-auto"
      style="font-family: Factul, sans-serif;">
      Confira como funciona o <span class="underline-inner">Comer bem sem estresse</span>:
    </h2>

    <!-- Subtitle: Inter 22px/33px white desktop, 13.26px mobile -->
    <p class="text-[3.4vw] lg:text-[22px] leading-[1.5em] lg:leading-[33px] text-white text-center uppercase tracking-[2.7px]"
      style="font-family: Inter, sans-serif;">
      Um método em 4 semanas
    </p>

    <!-- Accordion container (f9e9553) -->
    <div class="bg-[#FCF9F2] rounded-t-[10px] px-[20px] lg:px-[40px] pt-[20px] pb-[40px] lg:pb-[60px] flex flex-col gap-[15px] w-full lg:w-[52%] min-h-[1106px] lg:min-h-[884px]">

      <!-- Week label -->
      <p class="text-[3.7vw] lg:text-[16px] leading-[24px]"
        style="font-family: Inter, sans-serif; color: rgba(116, 116, 116, 0.72); font-style: italic;">
        Clique nos módulos para saber mais
      </p>

      <!-- Accordion -->
      <div class="flex flex-col gap-[12px] lg:gap-[19px]">
        {accordionItems.map((item, idx) => (
          <details class="group"
            >
            <summary class="flex items-center justify-between p-[20px] gap-x-[10px] cursor-pointer list-none [&::-webkit-details-marker]:hidden rounded-[10px] border border-[#D5D8DC]" style="background: linear-gradient(45deg, #C47519 0%, #E7B478 100%);">
              <div style="font-family: Inter, sans-serif;">
                <span class="inline-flex items-center bg-white text-[#C47519] text-[16px] font-semibold leading-[27.2px] rounded-full" style="padding: 5px 13px 4px;">
                  {item.week}
                </span><br />
                <span class="text-white text-[16px] font-semibold leading-[27.2px]">
                  {item.phase}
                </span>
              </div>
              <!-- Caret icon -->
              <svg class="w-[14px] h-[23px] lg:w-[9px] lg:h-[15px] text-white flex-shrink-0 transition-transform duration-300 group-open:rotate-180" viewBox="0 0 320 512" fill="currentColor">
                <path d="M31.3 192h257.3c17.8 0 26.7 21.5 14.1 34.1L174.1 354.8c-7.8 7.8-20.5 7.8-28.3 0L17.2 226.1C4.6 213.5 13.5 192 31.3 192z"/>
              </svg>
            </summary>
            <!-- Content: border-left 2px #c69778 with margin-left 25px -->
            <div class="acc-content p-[20px] flex flex-col gap-[20px]">
              <p class="text-[18px] lg:text-[18px] font-semibold italic leading-[27px]"
                style="font-family: Inter, sans-serif; color: rgba(0, 0, 0, 0.83);">
                {item.subtitle}
              </p>
              <p class="text-[17px] lg:text-[17px] leading-[25.5px]"
                style="font-family: Inter, sans-serif; color: rgba(0, 0, 0, 0.83);">
                {item.desc}
              </p>
              <ul class="flex flex-col gap-[8px] mt-[5px]">
                {item.modules.map(mod => (
                  <li class="text-[16px] lg:text-[16px] leading-[24px] flex gap-[8px]"
                    style="font-family: Inter, sans-serif; color: rgb(51, 51, 51);">
                    <svg class="w-[35px] h-[22px] flex-shrink-0 mt-[2px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 60"><rect fill="#6bb577" height="58" rx="7" width="58" x="1" y="1"/><path d="m24.375 47c-.892 0-1.751-.356-2.386-.996l-11.989-12.239c-1.312-1.339-1.312-3.51 0-4.849 1.312-1.339 3.44-1.339 4.752 0l9.623 9.824 19.273-19.677c1.312-1.339 3.44-1.339 4.752 0 1.312 1.339 1.312 3.51 0 4.849l-21.639 22.092c-.635.64-1.494.996-2.386.996z" fill="#fff"/></svg>
                    <span set:html={mod} />
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.acc-content').forEach(content => {
    const details = content.closest('details');
    const summary = details.querySelector('summary');
    
    summary.addEventListener('click', (e) => {
      e.preventDefault();
      
      if (details.open) {
        // Close animation
        content.style.maxHeight = content.scrollHeight + 'px';
        content.style.opacity = '1';
        requestAnimationFrame(() => {
          content.style.maxHeight = '0';
          content.style.opacity = '0';
        });
        content.addEventListener('transitionend', () => {
          details.open = false;
        }, { once: true });
      } else {
        // Open animation
        details.open = true;
        content.style.maxHeight = '0';
        content.style.opacity = '0';
        requestAnimationFrame(() => {
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.opacity = '1';
        });
        content.addEventListener('transitionend', () => {
          content.style.maxHeight = 'none';
        }, { once: true });
      }
    });
  });
</script>
