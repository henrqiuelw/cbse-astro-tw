---
const HOTMART = "https://pay.hotmart.com/N90113161T?off=ukulpso1";

const diferenciais = [
  {
    titulo: "Método Estruturado",
    descBold: "É um método criado por uma nutricionista especialista em Seletividade alimentar e desenvolvimento infantil",
    descRegular: "Você não recebe opiniões soltas, mas um sistema com lógica clara de aplicação",
  },
  {
    titulo: "Mudança de Fundamento",
    descBold: "Atua na causa do repertório alimentar restrito, e não apenas no comportamento à mesa.",
    descRegular: "O foco não é convencer a criança a comer, mas criar condições favoráveis para ela avançar.",
  },
  {
    titulo: "Sequência Progressiva",
    descBold: "Segue uma sequência lógica de etapas, aplicáveis à rotina real da família.",
    descRegular: "Cada fase prepara para a próxima, evitando tentativas aleatórias ou mudanças radicais.",
  },
  {
    titulo: "Autonomia Alimentar",
    descBold: "Desenvolve autonomia alimentar progressiva, com menos intervenção e menos negociação.",
    descRegular: "A alimentação deixa de ocupar o centro da rotina e vira uma atividade normal.",
  },
  {
    titulo: "Flexível ao Desenvolvimento",
    descBold: "Permite ajustar o método às necessidades alimentares e ao momento de desenvolvimento do seu filho.",
    descRegular: "Sem fórmulas engessadas: método com critério.",
  },
];
---

<!-- Gold gradient strip -->
<div class="metodo-gold-strip"></div>

<!-- Seção O Método -->
<section class="metodo-section">
  <div class="metodo-inner">

    <!-- Heading -->
    <h1 class="metodo-heading">
      <span class="underline-inner">O Comer bem sem estresse é um método estruturado</span> para sair do improviso e construir autonomia alimentar:
    </h1>

    <!-- 2-column layout: image left, cards right -->
    <div class="metodo-content">
      
      <!-- Left column: decorative image (desktop only) -->
      <div class="metodo-img-col">
        <img
          src="/img/083313-copy.webp"
          alt="Comer Bem Sem Estresse — módulos do curso"
          width="743"
          height="740"
          class="metodo-img"
          loading="lazy"
        />
      </div>

      <!-- Right column: 5 cards vertical -->
      <div class="metodo-cards-col">
        {diferenciais.map((d) => (
          <div class="metodo-card">
            <!-- Checkmark icon -->
            <img src="/img/141704.svg" alt="" width="46" height="46" class="metodo-icon" loading="lazy" />
            <!-- Title -->
            <p class="metodo-card-title">{d.titulo}</p>
            <!-- Bold description with green border -->
            <p class="metodo-card-desc-bold">{d.descBold}</p>
            <!-- Regular description -->
            <p class="metodo-card-desc">{d.descRegular}</p>
          </div>
        ))}
      </div>

    </div>

    <!-- CTA -->
    <div class="metodo-cta-wrap">
      <a
        href={HOTMART}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-grad metodo-cta"
      >
        Quero um sistema que funcione
      </a>
    </div>

  </div>
</section>

<style>
  /* Gold strip */
  .metodo-gold-strip {
    height: 20px;
    background: linear-gradient(90deg, #feb45d 0%, #fdd8ac 100%);
  }

  /* Section */
  .metodo-section {
    background-color: #fef4df;
    padding: 0;
  }

  .metodo-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 60px 0 200px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  @media (max-width: 1024px) {
    .metodo-inner {
      padding: 60px 40px 120px 40px;
    }
  }
  @media (max-width: 767px) {
    .metodo-inner {
      padding: 10% 5% 15% 5%;
    }
  }

  /* Heading */
  .metodo-heading {
    font-family: 'Factul', sans-serif;
    font-size: 32px;
    font-weight: 400;
    line-height: 1.2em;
    color: #1c3124;
    text-align: center;
    text-wrap: balance;
    margin: 0 0 40px 0;
  }
  @media (min-width: 768px) and (max-width: 1024px) {
    .metodo-heading {
      font-size: 36px;
    }
  }
  @media (max-width: 767px) {
    .metodo-heading {
      font-size: 6.1vw;
      margin-bottom: 30px;
    }
  }

  /* 2-column content (image left, cards right) */
  .metodo-content {
    display: flex;
    flex-direction: row;
    gap: 40px;
    width: 100%;
    max-width: 1140px;
    margin-bottom: 40px;
    align-items: flex-start;
  }
  @media (max-width: 1024px) {
    .metodo-content {
      flex-direction: column;
      gap: 30px;
    }
  }

  /* Left column: image (desktop only) */
  .metodo-img-col {
    flex: 0 0 auto;
    width: 320px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }
  @media (max-width: 1024px) {
    .metodo-img-col {
      display: none;
    }
  }

  .metodo-img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* Right column: cards vertical */
  .metodo-cards-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  /* Card */
  .metodo-card {
    background-color: #fffefb;
    border-radius: 10px;
    padding: 40px;
    box-shadow: 0 34.319px 44.764px 0 rgba(0, 0, 0, 0.06);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Icon with hover rotation */
  .metodo-icon {
    width: 46px;
    height: 46px;
    margin-bottom: 16px;
    transition: transform 0.3s ease;
  }
  .metodo-card:hover .metodo-icon {
    transform: rotate(136deg);
  }

  /* Card title */
  .metodo-card-title {
    font-family: 'Factul', sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.3em;
    color: #584c4d;
    margin: 0 0 16px 0;
  }

  /* Bold description with green left border */
  .metodo-card-desc-bold {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.3em;
    color: #584c4d;
    border-left: 2px solid #58dbb1;
    padding-left: 20px;
    margin: 0 0 16px 0;
  }

  /* Regular description */
  .metodo-card-desc {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.4em;
    color: #584c4d;
    margin: 0;
  }

  /* CTA */
  .metodo-cta-wrap {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .metodo-cta {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.9px;
    text-transform: uppercase;
    padding: 20px 40px;
  }
</style>
