---
// PhasesSection.astro — Container 7 (id: f16fc3e)
// JSON source: page-2.json
//
// Section: bg #FEF4DF, boxed 1140px, flex-row wrap
//   padding: 200px 0 60px 0 (desktop), 27% 0 10% 0 (mobile)
//
// Top image (b05e045): hidden desktop, visible mobile
//   _margin_mobile: -39% 0 -34% 0
//
// Heading (b30ec4e): Factul 32px/400 desktop, 5.4vw mobile
//   width: 54.82% desktop, color #1C3124
//
// Lottie hint (73da13f): "Arraste para ver todas as fases"
//
// Phases container (9357eda): flex-row, overflow auto, width 70%
//   padding: 40px 0 0 0
//   Mobile: horizontal scroll
//
// Each phase card: bg #5A866D, padding 40px, rounded 10px
//   Phase label: Factul 18px/400, #FFFFFF
//   Phase title: Factul 22px/400, #FFDDB5
//   Phase desc: Inter 18px/400, #FFFFFF
//   Phase icon: SVG

const phases = [
  {
    label: 'FASE 1',
    title: 'Diagnóstica',
    desc: 'Identifique as causas das recusas e comece a mudar a percepção do seu filho com a comida.',
    icon: 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/031055.svg',
  },
  {
    label: 'FASE 2',
    title: 'Estruturação',
    desc: 'Reestruture e neutralize os fatores fortalecedores da seletividade alimentar, tornando o ambiente favorável a novas experimentações, aumentando a segurança e a autonomia do seu filho',
    icon: 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/021055.svg',
  },
  {
    label: 'FASE 3',
    title: 'Alimentar',
    desc: 'Estratégias de aproximação e exposição dos alimentos e a oferta lúdica. Nessa fase, o pequeno já foi preparado e está aberto a novas experimentações.',
    icon: 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/011055.svg',
  },
  {
    label: 'FASE 4',
    title: 'Consolidação',
    desc: 'Ferramentas lúdicas para consolidar a aplicação da metodologia e incentivar o seu filho a comer com naturalidade e autonomia',
    icon: 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/110074060.svg',
  },
];

const decorativeUrl = 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/133907-copy.webp';
---

<section
  class="flex flex-col overflow-visible"
  style="background-color: #FEF4DF;"
>
  <div class="w-full max-w-[1140px] mx-auto flex flex-row flex-wrap justify-center items-center gap-[30px] lg:gap-[20px]
    pt-[27%] pb-[10%] px-0
    md:pt-[200px] md:pb-[60px] md:px-0">

    <!-- Top image (b05e045): hidden desktop, visible mobile -->
    <div class="lg:hidden w-full overflow-visible">
      <div style="margin: -39% 0 -34% 0;">
        <img src={decorativeUrl} alt="" class="w-full h-auto" loading="lazy" />
      </div>
    </div>

    <!-- Heading (b30ec4e): 54.82% desktop -->
    <div class="w-full lg:w-[54.82%] text-center px-[5%] lg:px-0">
      <h2 class="font-factul font-normal text-[5.4vw] md:text-[32px]
        leading-[1.2em] text-[#1C3124]"
        style="text-wrap: balance !important;">
        Na metodologia Comer bem sem estresse você seguirá
        <span class="underline-inner">uma trilha de conhecimento</span>
        que vai preparar o seu filho
        <span class="underline-inner"> para avançar com autonomia: </span>
      </h2>
    </div>

    <!-- Lottie hint (73da13f): "Arraste para ver" - mobile only -->
    <div class="lg:hidden relative flex flex-col gap-[20px] w-[90%] p-[10px]">
      <!-- Lottie animated arrow: absolute, top-right -->
      <script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js" is:inline></script>
      <lottie-player
        src="https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/Animation-1699547373843.json"
        background="transparent"
        speed="1"
        class="absolute"
        style="width: 70px; height: 77px; top: -19px; right: -14px;"
        loop
        autoplay
      ></lottie-player>
      <p class="text-[15.6px] text-[#584C4D] text-center" style="font-family: Inter, sans-serif; font-style: italic;">
        Arraste para ver todas as fases
      </p>
    </div>

    <!-- Phases container (9357eda): flex-row, overflow auto, 70% desktop -->
    <div class="w-full lg:w-[70%] flex flex-row lg:grid lg:grid-cols-2 gap-[20px] lg:gap-[30px] overflow-x-auto lg:overflow-visible pt-0 lg:pt-[40px] pb-0 lg:pb-0 lg:px-0 lg:items-stretch lg:auto-rows-fr
      snap-x snap-mandatory scroll-smooth"
      style="-webkit-overflow-scrolling: touch; padding-inline: 20px; scroll-padding-inline: 20px;">

      {phases.map((phase) => (
        <div
          class="phase-card relative flex-shrink-0 w-[305px] md:w-auto md:flex-1
            flex flex-col gap-[20px] p-[35px] lg:p-[40px] rounded-[10px] overflow-hidden
            snap-start"
          style="background: radial-gradient(#5A866D 0%, #244030 100%);"
        >
          <!-- Phase label: pill badge -->
          <p class="font-factul font-normal text-[18px] leading-[23.4px] text-white inline-block self-start"
            style="font-family: Factul, sans-serif; background: rgba(90, 134, 109, 0.36); padding: 10px 30px 7px; border-radius: 100px; border: 1px solid rgba(255, 255, 255, 0.44);">
            {phase.label}
          </p>

          <!-- Phase title: Factul 22px/400, #FFDDB5 -->
          <p class="font-factul font-normal text-[22px] leading-[28.6px] text-[#FFDDB5]" style="font-family: Factul, sans-serif;">
            {phase.title}
          </p>

          <!-- Phase desc: Inter 18px/400, white -->
          <p class="text-[18px] leading-[23.4px] text-white pl-[20px]" style="font-family: Inter, sans-serif;">
            {phase.desc}
          </p>

          <!-- Phase icon: absolute watermark, bottom-right -->
          <img src={phase.icon} alt="" class="absolute bottom-[17px] right-0 w-[80%] h-auto pointer-events-none" loading="lazy" />
        </div>
      ))}
    </div>

    <!-- Button CTA (ea51b4b) -->
    <div class="btn-sweep block lg:inline-block rounded-[100px] mx-[5%] lg:mx-0"
      style="background: linear-gradient(to right, #2D8050 0%, #1FBF63 51%, #2D8050 100%); background-size: 200%; background-position: 0% 0%; transition: 0.5s;">
      <a
        href="https://pay.hotmart.com/N90113161T?off=ukulpso1"
        class="block lg:inline-block text-[14px] lg:text-[16px] font-semibold uppercase tracking-[0.9px] text-white
          px-[30px] lg:px-[40px] py-[20px] leading-[16px] rounded-[100px] text-center"
        style="font-family: Inter, sans-serif; background-color: rgba(97, 206, 112, 0);"
      >
        Quero um sistema que funcione
      </a>
    </div>
  </div>
</section>

<style>
  @media (max-width: 1024px) {
    .phase-card {
      background: radial-gradient(at 100% 0%, #5A866D 0%, #244030 48%) !important;
    }
  }
</style>
