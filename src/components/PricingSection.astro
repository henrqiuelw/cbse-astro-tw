    margin: -26px 0 -24px 0;
  }

  /* Button: full-width mobile (align_mobile: justify), pad mobile */
  .pricing-btn {
    padding: 20px 30px;
    border-radius: 100px;
    display: block;
    align-self: center;
    /* justify on mobile - button fills available width */
  }
  .pricing-btn:hover { background-position: right center; }
  .pricing-list s { text-decoration-color: red; text-decoration-thickness: 2px; }

  /* RIGHT: full width mobile, list 259px centered */
