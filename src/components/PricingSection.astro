  .pricing-right-list { width: 259px; }

  /* ============ DESKTOP ============ */
  @media (min-width: 1025px) {
    .pricing-section {
      background-image: linear-gradient(11deg, #244030 0%, #39664C 100%);
      padding: 0 40px;
    }
    .pricing-inner {
      max-width: 1080px;
