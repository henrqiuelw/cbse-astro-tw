      padding: 0;
    }
    /* "12x" and ",72" margin desktop: -10px 0 */
    .pricing-12x, .pricing-cents {
      margin: -10px 0;
    }
    /* "R$ 30" margin reset desktop */
    .pricing-main {
      margin: 0;
    }
    /* Button desktop */
    .pricing-btn {
      padding: 20px 40px;
      border-radius: 1000px;
      width: auto;
      align-self: center;
    }
    .pricing-right {
      width: 30%;
      align-self: auto;
    }
    .pricing-right-list { width: 100%; }
