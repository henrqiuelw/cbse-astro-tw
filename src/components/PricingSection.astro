<section class="pricing-section w-full flex flex-col items-center px-[19.5px] lg:px-[40px]">
  <div class="w-full max-w-[767px] lg:max-w-[1080px] flex flex-col lg:flex-row items-center justify-center" style="gap: 20px; padding-top: 52.64px; padding-bottom: 126.36px;">

    <!-- Left: Heading + Bonus items (75514e9) -->
    <div class="flex flex-col items-center lg:items-start lg:w-[291px] w-full" style="gap: 20px;">
      <h2
        class="text-[6.7vw] lg:text-[29px] leading-[1.2em] text-white font-normal text-center lg:text-left"
        style="font-family: Factul, sans-serif;"
      >
        Fazendo a sua inscrição hoje, você vai receber:
      </h2>
      <ul class="flex flex-col w-full">
        {leftItems.map((item) => (
          <li class="flex items-start gap-[10px]" style="padding-bottom: 15px;">
            <span class="flex-shrink-0 w-[46px] h-[46px]" set:html={checkIcon} />
            <span class="text-[16px] leading-[24px] text-white font-normal" style="font-family: Inter, sans-serif;">
              {item.text} <s>{item.price}</s>
            </span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Center: Image + Price + CTA (a89e89a) -->
    <div
      class="pricing-center-card flex flex-col rounded-[10px] w-full lg:w-[458px] overflow-visible mt-[137px] lg:-mt-[60px]"
      style="background: linear-gradient(360deg, #EBE4DF 0%, #FFFFFF 100%); padding: 35px; gap: 20px; box-shadow: rgba(0, 0, 0, 0.09) 0px 10px 30px 0px;"
    >
      <!-- Product image: widget height + wrapper margin-top from computed -->
      <div class="pricing-img-widget w-full overflow-visible">
        <div class="pricing-img-wrapper overflow-visible">
          <img
            src="https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/113007.webp"
            alt="Comer Bem Sem Estresse - Kit completo"
            class="pricing-img w-[463px] max-w-none lg:w-[513px] h-auto block"
            loading="lazy"
          />
        </div>
      </div>

      <!-- "Receba tudo isso" (e433eaf) -->
      <h3
        class="text-[30px] lg:text-[36px] font-normal text-center"
        style="font-family: Factul, sans-serif; color: rgb(90, 90, 90); line-height: 1.1em;"
      >
        <span class="underline-inner">Receba tudo isso</span>
      </h3>

      <!-- "por apenas" (4394b31) -->
      <p
        class="text-[22px] font-normal text-center"
        style="font-family: Inter, sans-serif; color: rgb(83, 83, 83); line-height: 33px;"
      >
        por apenas
      </p>

      <!-- Price block (81528ab): flex-row, align-items flex-end, gap 5px -->
      <div class="pricing-price-row flex items-center justify-center w-full" style="gap: 5px; border-top: 1px solid rgba(0, 0, 0, 0.11); border-bottom: 1px solid rgba(0, 0, 0, 0.11); padding: 20px 0;">
        <span class="text-[26px] font-normal" style="font-family: Inter, sans-serif; color: rgb(71, 71, 71); line-height: 39px;">12x</span>
        <span class="text-[62.4px] lg:text-[94px] font-semibold pricing-price-main" style="font-family: Inter, sans-serif; color: rgba(36, 34, 35, 0.28);">R$&nbsp;<span style="color: #f89a2b;">30</span></span>
        <span class="text-[23px] lg:text-[26px] font-normal" style="font-family: Inter, sans-serif; color: rgb(32, 32, 32); line-height: 1em;">,72</span>
      </div>

      <!-- "ou R$ 297,00 à vista" (39a6bd3) -->
      <p
        class="text-[20px] lg:text-[22px] font-normal text-center leading-[33px]"
        style="font-family: Inter, sans-serif; color: rgb(83, 83, 83); line-height: 30px;"
      >
        ou R$ 297,00 à vista
      </p>

      <!-- CTA Button (9abaca9) -->
      <a
        href="https://pay.hotmart.com/N90113161T?off=ukulpso1"
        class="pricing-btn text-center text-[14px] lg:text-[16px] font-semibold uppercase text-white self-center inline-block leading-[1.2em]"
        style="font-family: Inter, sans-serif; padding: 20px 30px; letter-spacing: 0.9px; border-radius: 100px; background-image: linear-gradient(to right, #2D8050 0%, #1FBF63 51%, #2D8050 100%); background-size: 200% auto; transition: 0.5s;"
      >
        COMEÇAR COM O MÉTODO
      </a>
    </div>

    <!-- Right: Benefits list (d287692) -->
    <div class="flex flex-col lg:w-[291px] w-full" style="gap: 20px;">
      <ul class="flex flex-col w-full">
        {rightItems.map((item) => (
          <li class="flex items-start gap-[10px]" style="padding-bottom: 15px;">
            <span class="flex-shrink-0 w-[46px] h-[46px]" set:html={checkIcon} />
            <span class="text-[16px] leading-[24px] text-white font-normal" style="font-family: Inter, sans-serif;">
              {item}
            </span>
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<style>
  .pricing-section {
    background-image: linear-gradient(279deg, rgb(36, 64, 48) 0%, rgb(57, 102, 76) 100%);
  }
  .pricing-img-widget { height: 52px; }
  .pricing-img-wrapper { margin-top: -171px; margin-left: -101px; margin-right: -81px; }
  .pricing-btn:hover { background-position: right center; }
  .pricing-price-main { line-height: 93.6px; }
  @media (min-width: 1025px) { .pricing-price-main { line-height: 141px; } }

  @media (min-width: 1025px) {
    .pricing-section {
      background-image: linear-gradient(11deg, rgb(36, 64, 48) 0%, rgb(57, 102, 76) 100%);
    }
    .pricing-center-card { padding: 80px 40px !important; }
    .pricing-img-widget { height: 4px; }
    .pricing-img-wrapper { margin-top: -242px; margin-left: -87px; margin-right: -49px; }
    .pricing-btn { padding: 20px 40px !important; }
    .pricing-price-row { padding: 0 !important; }
    .pricing-section > div { padding-top: 0 !important; padding-bottom: 0 !important; }
  }
</style>
