    }
    .pricing-left {
      width: 30%;
    }
    .pricing-center-card {
      width: 500px;
      padding: 80px 40px;
      margin: -60px 0;
      border-width: 6px;
    }
    /* Image wrapper margins desktop: -64% -13% -12% -23% */
