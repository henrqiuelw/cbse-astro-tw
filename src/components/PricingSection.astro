const leftItems = [
  { text: 'Receitas para crianças seletivas', price: 'R$69,00' },
  { text: 'Diário da Conexão com a comida', price: 'R$69,00' },
  { text: 'Kit Brincando de Comer', price: 'R$99,00' },
];

const rightItems = [
  'Acesso imediato após a confirmação do pagamento',
  'Sem taxas escondidas.',
  'Garantia de 7 dias',
];

