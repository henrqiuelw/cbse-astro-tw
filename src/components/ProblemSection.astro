---
// ProblemSection.astro — Container 2 (id: 239a7bd)
// Validado com Playwright iPhone 14 emulation

const problems = [
  { text: 'Seu filho mantém um <span style="font-weight: 600;">repertório alimentar restrito</span>, mesmo você oferecendo variedade' },
  { text: 'A alimentação dele depende de <span style="font-weight: 600;">negociação constante</span>' },
  { text: 'Você sente que faz "tudo certo", mas <span style="font-weight: 600;">não vê evolução consistente</span>' },
  { text: 'Falta clareza sobre <span style="font-weight: 600;">o que fazer, quando insistir e quando recuar</span>' },
  { text: 'A alimentação ocupa <span style="font-weight: 600;">energia mental excessiva da família</span>' },
];

const iconUrl = 'https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/102804.svg';
---

<!--
  Playwright iPhone 14 measurements (ORIGINAL):
  - Widget e419bbf: w:351px (100%), NOT 67.837%
  - .elementor-widget-container: margin 0 -20px → w:391px (overflows)
  - h1 inside: w:391px, fs:23.79px (6.1vw), lh:1.2em, 4 lines
  - Icon list: w:273.8px (78%), gap between items: 12.5px
  - Insight d134f69: container margin 0 -20px → w:391px
  - Conclusion c3e0998: container margin 0 -20px → w:391px
-->

<section
  class="flex flex-col justify-center items-center
    px-[5%] pt-[10%] pb-[10%]
    md:pt-[5%] md:px-[5%] md:pb-[10%]
    lg:pt-[40px] lg:px-0 lg:pb-[60px]
    lg:mt-[-28px]"
  style="background-color: #FFFFFF; border-top: 1px solid #FFFFFF0F;"
>
  <div class="w-full max-w-[1140px] mx-auto flex flex-col items-center gap-[20px]">

    <!-- Inner (e6fdafd): 81% desktop, 100% mobile, p:60px 40px desktop -->
    <div class="w-full lg:w-[81%] p-0 lg:p-[60px_40px] flex flex-col items-center gap-[20px]">

      <!-- Heading 1 (e419bbf): w:100% mobile, 66% desktop -->
      <!-- Container margin: 0 -20px mobile (text overflows to 391px) -->
      <div class="w-full md:w-[516px] lg:w-[66%] self-center text-center">
        <div class="mx-[-20px] md:mx-0">
          <h2 class="font-factul font-normal text-[6.1vw] md:text-[36px] lg:text-[32px] leading-[1.2em] text-[#1C3124]">
            <span class="underline-inner">O problema não está no que o seu filho não come,</span> mas na ausência de um sistema alimentar favorável:
          </h2>
        </div>
      </div>

      <!-- Icon list (0367680): 65.778% desktop, 78% mobile -->
      <ul class="w-[78%] md:w-[78%] lg:w-[65.778%] self-center flex flex-col">
        {problems.map((problem, i) => (
          <li class:list={["flex items-start pb-[12.5px] md:pb-[15px] lg:pb-[14.5px]", i > 0 && "problem-divider", i === problems.length - 1 && "!pb-0"]}>
            <img src={iconUrl} alt="" class="w-[27.5px] h-[22px] flex-shrink-0 mt-[5px] md:mt-0 object-contain object-left" width="22" height="22" />
            <span class="font-normal text-[16px] leading-[1.5em] italic text-[#1C1E20]" style="font-family: Inter, sans-serif;" set:html={problem.text} />
          </li>
        ))}
      </ul>
    </div>

    <!-- Heading 2 / Insight (d134f69): w:100% mobile, 87% desktop -->
    <div class="w-full md:w-[516px] lg:w-[87%] self-center text-center">
      <div class="mx-[-20px] mb-[-20px] md:mx-0 md:mb-0">
        <h3 class="font-factul font-normal text-[4.5vw] md:text-[26px] lg:text-[24px] leading-[1.3em] md:leading-[1.2em] text-[#1C3124]">
          Se você já tentou diferentes abordagens e ainda não vê evolução consistente na alimentação do seu filho,
        </h3>
      </div>
    </div>

    <!-- Heading 3 / Conclusão (c3e0998): Factul 33px, mt:-18px desktop -->
    <div class="w-full md:w-[516px] lg:w-[87%] self-center text-center lg:mt-[-18px]">
      <div class="mx-[-20px] md:mx-0">
        <h3 class="font-factul font-normal text-[6.2vw] md:text-[36px] lg:text-[33px] leading-[1.3em] md:leading-[1.2em] text-[#1C3124]">
          <span class="underline-inner">o problema não é esforço, é ausência de método.</span>
        </h3>
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .problem-divider {
      border-top: 1px solid #e5e5e5;
      padding-top: 30px;
    }
  }
  @media (min-width: 1025px) {
    .problem-divider {
      border-top: 1px solid #e5e5e5;
      padding-top: 29px;
    }
  }
</style>
