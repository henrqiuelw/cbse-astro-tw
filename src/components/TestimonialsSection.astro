---
// TestimonialsSection.astro — Container 12 (421c60c)
//
// JSON SECTION (421c60c):
//   bg: #FFFFFF, content_width: full, flex: column, gap 20px
//   justify: space-between
//   pad desktop: 80px 0 240px 0
//   pad laptop: 60px 0 240px 0
//   pad tablet: 60px 20px
//   pad mobile: 15% 5% 15% 5%
//
// JSON HEADING (5209077):
//   h1, Factul 37px/5.1vw mobile, weight 400, color #3A3A3A
//   lh: 1.3em desktop, 1.2em mobile
//   width: 651px desktop, inherit mobile (full)
//   alignSelf: center, align: center, _padding: 0
//
// JSON CAROUSEL (48505f6):
//   slides: 5 desktop, 3 tablet, 2 mobile
//   image_stretch: yes, thumbnail_size: full
//   image_spacing_custom_mobile: 15px (default desktop: 20px)
//   image_border: 1px solid #00000014, radius 20px desktop / 10px mobile
//   _margin_mobile: 0 -6% 0 -6% (extends carousel beyond section padding)
//   navigation: dots, slides_to_scroll: 1
//   custom_css: swiper-wrapper transition-timing-function linear

const testimonials = [
  'Depoimento-CBSE-I.png',
  'Depoimento-CBSE-XIII.png',
  'Depoimento-CBSE-XII.png',
  'Depoimento-CBSE-XI.png',
  'Depoimento-CBSE-X.png',
  'Depoimento-CBSE-VIII.png',
  'Depoimento-CBSE-VII.png',
  'Depoimento-CBSE-VI.png',
  'Depoimento-CBSE-V.png',
  'Depoimento-CBSE-IX.png',
  'Depoimento-CBSE-IV.png',
  'Depoimento-CBSE-III.png',
  'Depoimento-CBSE-II.png',
];

const baseUrl = 'https://comerbemsemestresse.com.br/wp-content/uploads/2025/08/';
---

<!-- Container 12: Depoimentos (421c60c) -->
<section class="testimonials-section w-full bg-white flex flex-col items-center justify-between">
  <!-- Heading (5209077) -->
  <h1 class="testimonials-heading text-center font-normal self-center"
    style="font-family: Factul, sans-serif; color: #3A3A3A; padding: 0;"
  >
    <span class="underline-inner">Veja os resultados de mães e alunas</span> que saíram do improviso com a alimentação dos seus filhos para seguir <span class="underline-inner">um método estruturado:</span>
  </h1>

  <!-- Carousel (48505f6) -->
  <div class="testimonials-swiper swiper self-center">
    <div class="swiper-wrapper">
      {testimonials.map((filename, i) => (
        <div class="swiper-slide">
          <img
            src={`${baseUrl}${filename}`}
            alt={`Depoimento ${i + 1}`}
            loading="lazy"
          />
        </div>
      ))}
    </div>
    <div class="swiper-pagination"></div>
  </div>
</section>

<style>
  /* === MOBILE (base) === */
  .testimonials-section {
    padding: 15% 5%;
    gap: 20px;
  }

  .testimonials-heading {
    font-size: 5.1vw;
    line-height: 1.2em;
    width: 100%;
  }

  .testimonials-swiper {
    width: 100%;
    width: calc(100% + 12%); margin-left: -6%; /* swiper extends 6% beyond each side */
    overflow: hidden;
  }

  /* Swiper linear transition (custom_css) */
  .testimonials-swiper :global(.swiper-wrapper) {
    transition-timing-function: linear !important;
  }

  /* Image styling from JSON */
  .testimonials-swiper :global(.swiper-slide img) {
    width: 100%;
    object-fit: cover; /* contain portrait images to uniform height */
    display: block;
    border: 1px solid rgba(0, 0, 0, 0.08); /* #00000014 */
    border-radius: 10px;
    box-sizing: border-box;
  }

    /* Fixed slide height to prevent overflow from portrait images */
  .testimonials-swiper :global(.swiper-slide) {
    height: 159px !important;
  }
  .testimonials-swiper :global(.swiper-slide img) {
    height: 152px;
  }

  /* Dots styling */
  .testimonials-swiper :global(.swiper-pagination-bullet) {
    width: 8px;
    height: 8px;
    background: rgb(0, 0, 0);
    opacity: 0.2;
    margin: 0 4px !important;
  }
  .testimonials-swiper :global(.swiper-pagination-bullet-active) {
    opacity: 1;
    background: rgb(0, 122, 255);
  }
  .testimonials-swiper :global(.swiper-pagination) {
    bottom: 5px !important;
  }

  /* === TABLET === */
  @media (min-width: 768px) {
    .testimonials-section {
      padding: 60px 20px;
    }
  }

  /* === DESKTOP === */
  @media (min-width: 1025px) {
    .testimonials-section {
      padding: 80px 0 240px;
    }
    .testimonials-heading {
      font-size: 37px;
      line-height: 1.3em;
      width: 651px;
    }
    .testimonials-swiper {
      margin-left: 0;
      width: 100%;
    }
    .testimonials-swiper :global(.swiper-slide img) {
      border-radius: 20px;
    }
  }
</style>

<script>
  import Swiper from 'swiper';
  import { Autoplay, Pagination } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/pagination';

  document.addEventListener('DOMContentLoaded', () => {
    new Swiper('.testimonials-swiper', {
      modules: [Autoplay, Pagination],
      slidesPerView: 2,
      spaceBetween: 15, // image_spacing_custom_mobile: 15px
      loop: true,
      autoHeight: true,
      speed: 500,
      slidesPerGroup: 1,
      autoplay: {
        delay: 5000,
        disableOnInteraction: true,
      },
      pagination: {
        el: '.testimonials-swiper .swiper-pagination',
        clickable: true,
      },
      breakpoints: {
        768: {
          slidesPerView: 3,
          spaceBetween: 20,
        },
        1025: {
          slidesPerView: 5,
          spaceBetween: 20,
        },
      },
    });
  });
</script>
