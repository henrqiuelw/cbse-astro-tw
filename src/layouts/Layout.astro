---
import '../styles/global.css';
import { getImage } from 'astro:assets';
import posterImage from '../assets/100104.webp';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "CBSE - Comer Bem Sem Estresse",
  description = "UM MÉTODO ESTRUTURADO PARA FAMÍLIAS QUE QUEREM RESULTADOS CONSISTENTES",
} = Astro.props;

// Gerar versão otimizada do poster para preload
const posterOptimized = await getImage({
  src: posterImage,
  width: 1080,
  format: 'webp',
  quality: 80
});
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/img/cropped-Ovo-fundo-verde.webp" sizes="32x32" />
    <link rel="icon" type="image/webp" href="/img/cropped-cropped-Ovo-fundo-verde.webp" sizes="192x192" />
    <link rel="apple-touch-icon" href="/img/cropped-cropped-Ovo-fundo-verde.webp" />

    <!-- Open Graph -->
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:type" content="article" />
    <meta property="og:title" content="Leve o seu filho de um repertório alimentar restrito para uma alimentação variada e saudável" />
    <meta property="og:description" content="UM MÉTODO ESTRUTURADO PARA FAMÍLIAS QUE QUEREM RESULTADOS CONSISTENTES" />
    <meta property="og:url" content="https://comerbemsemestresse.com.br/cbse/" />
    <meta property="og:site_name" content="Comer Bem Sem Estresse" />
    <meta property="og:image" content="/img/15111-copy.webp" />
    <meta property="og:image:width" content="230" />
    <meta property="og:image:height" content="340" />
    <meta property="og:image:type" content="image/webp" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Preload Fonts -->
    <link rel="preload" href="/fonts/fractul-regular-webfont.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/fractul-light-webfont.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/fractul-medium-webfont.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/fractul-bold-webfont.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

    <!-- Google Fonts: Inter + Nunito -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Nunito:wght@600;700&display=swap" rel="stylesheet" />

    <!-- Preload Hero Background -->
    <link rel="preload" as="image" href="/img/093713-copy.webp" fetchpriority="high" />
    
    <!-- Preload Video Poster (LCP) -->
    <link rel="preload" as="image" href={posterOptimized.src} fetchpriority="high" />

    <title>{title}</title>

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "@id": "https://comerbemsemestresse.com.br/cbse/",
          "url": "https://comerbemsemestresse.com.br/cbse/",
          "name": "CBSE - Comer Bem Sem Estresse",
          "isPartOf": { "@id": "https://comerbemsemestresse.com.br/#website" },
          "thumbnailUrl": "/img/095704.svg",
          "description": "UM MÉTODO ESTRUTURADO PARA FAMÍLIAS QUE QUEREM RESULTADOS CONSISTENTES",
          "inLanguage": "pt-BR"
        },
        {
          "@type": "WebSite",
          "@id": "https://comerbemsemestresse.com.br/#website",
          "url": "https://comerbemsemestresse.com.br/",
          "name": "Comer Bem Sem Estresse",
          "inLanguage": "pt-BR"
        }
      ]
    })} />
  </head>
  <body class="font-inter bg-creme text-texto">
    <slot />
  </body>
</html>
