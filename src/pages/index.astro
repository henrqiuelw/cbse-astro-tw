---
import HeroSection from '../components/HeroSection.astro';
import ProblemSection from '../components/ProblemSection.astro';
import SystemSection from '../components/SystemSection.astro';
import DividerBar from '../components/DividerBar.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="pt-BR" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Comer Bem Sem Estresse - Nutrição Infantil" />
    <title>Comer Bem Sem Estresse</title>
    <link rel="preconnect" href="https://fonts-api.wp.com">
    <link rel="preconnect" href="https://fonts.wp.com" crossorigin>
  </head>
  <body class="font-sans text-text-primary bg-white overflow-x-hidden">
    <!-- Container 0: Divider bar topo -->
    <div class="h-1" style="background-color: #FEB45D;"></div>

    <!-- Container 1: Hero -->
    <HeroSection />

    <!-- Container 2: Problem -->
    <ProblemSection />

    <!-- Container 3: System -->
    <SystemSection />

    <!-- Container 4: Divider bar -->
    <DividerBar />

    <!-- Container 5: Features -->
    <FeaturesSection />

    <!-- Containers 6-18: TODO -->
  </body>
</html>
