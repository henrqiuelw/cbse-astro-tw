---
import HeroSection from '../components/HeroSection.astro';
import ProblemSection from '../components/ProblemSection.astro';
import SystemSection from '../components/SystemSection.astro';
import DividerBar from '../components/DividerBar.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import ComparisonSection from '../components/ComparisonSection.astro';
import PhasesSection from '../components/PhasesSection.astro';
import BioSection from '../components/BioSection.astro';
import HowItWorksSection from '../components/HowItWorksSection.astro';
import BonusSection from '../components/BonusSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import PricingSection from '../components/PricingSection.astro';
import GradientDivider2 from '../components/GradientDivider2.astro';
import GarantiaSection from '../components/GarantiaSection.astro';
import CtaFinalSection from '../components/CtaFinalSection.astro';
import FaqSection from '../components/FaqSection.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="pt-BR" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Comer Bem Sem Estresse - Nutrição Infantil" />
    <title>Comer Bem Sem Estresse</title>
    <link rel="preconnect" href="https://fonts-api.wp.com">
    <link rel="preconnect" href="https://fonts.wp.com" crossorigin>
    <link rel="preload" as="image" href="https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/093713-copy.webp" fetchpriority="high">
    <link rel="preload" as="image" href="https://comerbemsemestresse.com.br/wp-content/uploads/2026/02/100004.webp" fetchpriority="high" media="(min-width: 768px)">
  </head>
  <body class="font-sans text-text-primary bg-white overflow-x-hidden">
    <!-- Container 0: Divider bar topo -->
    <div class="min-h-[6px] md:min-h-[10px]" style="background-color: #FEB45D;"></div>

    <!-- Container 1: Hero -->
    <HeroSection />

    <!-- Container 2: Problem -->
    <ProblemSection />

    <!-- Container 3: System -->
    <SystemSection />

    <!-- Container 4: Divider bar -->
    <DividerBar />

    <!-- Container 5: Features -->
    <FeaturesSection />
    <ComparisonSection />
    <PhasesSection />
    <BioSection />
    <HowItWorksSection />
    <BonusSection />
    <TestimonialsSection />
    <PricingSection />
    <GradientDivider2 />
    <GarantiaSection />
    <CtaFinalSection />
    <FaqSection />
    <Footer />

    <!-- Containers 6-18: TODO -->
  </body>
</html>
