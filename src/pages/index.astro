---
import Layout from '../layouts/Layout.astro';
import GradientBar from '../components/GradientBar.astro';
import Hero from '../components/Hero.astro';
import Problemas from '../components/Problemas.astro';
import Metodo from '../components/Metodo.astro';
import Comparacao from '../components/Comparacao.astro';
import Fases from '../components/Fases.astro';
import SobreFlavia from '../components/SobreFlavia.astro';
import ComoFunciona from '../components/ComoFunciona.astro';
import Bonus from '../components/Bonus.astro';
import Depoimentos from '../components/Depoimentos.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <!-- 0. Barra gradiente topo -->
  <GradientBar />

  <!-- 1. Hero -->
  <Hero />

  <!-- 2. Problemas / Dores -->
  <Problemas />

  <!-- 3. O Método (diferenciais) -->
  <Metodo />

  <!-- 4. Comparação Antes/Depois -->
  <Comparacao />

  <!-- 5. Fases visuais -->
  <Fases />

  <!-- 6. Sobre a Flávia -->
  <SobreFlavia />

  <!-- 7. Como Funciona (módulos / semanas) -->
  <ComoFunciona />

  <!-- 8. Bônus -->
  <Bonus />

  <!-- 9. Depoimentos -->
  <Depoimentos />

  <!-- 10. Pricing / Oferta -->
  <Pricing />

  <!-- 11. FAQ -->
  <FAQ />

  <!-- 12. Footer -->
  <Footer />
</Layout>
